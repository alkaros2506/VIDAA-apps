{
  "name": "@tv-app/wasm-engine",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "asbuild:debug": "asc assembly/index.ts --target debug",
    "asbuild:release": "asc assembly/index.ts --target release",
    "asbuild": "npm run asbuild:release",
    "build": "npm run asbuild && tsc --project tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist build coverage"
  },
  "dependencies": {},
  "devDependencies": {
    "assemblyscript": "^0.27.0",
    "vitest": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
