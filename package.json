{
  "name": "tv-app-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Cookiecutter monorepo for building TV apps — VIDAA, tvOS, and more",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "dev": "turbo run dev --filter=example-app",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=20.0.0"
  }
}
